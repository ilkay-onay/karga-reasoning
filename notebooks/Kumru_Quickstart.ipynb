# Hücre 2
import torch
from transformers import AutoModelForCausalLM, AutoTokenizer

print("Model yükleniyor...")
model_id = "YOUR-HF-USERNAME/Kumru-2B-Reasoning"
tokenizer = AutoTokenizer.from_pretrained(model_id)
model = AutoModelForCausalLM.from_pretrained(model_id, device_map="auto", torch_dtype=torch.bfloat16)

# Hücre 3
soru = "Bir tarlada 5 koyun ve 3 tavuk vardır. Toplam kaç ayak vardır? Adım adım hesapla."
messages = [
    {"role": "system", "content": "Adın Kumru. Soruları mantıklı ve adım adım düşünerek yanıtla."},
    {"role": "user", "content": soru}
]

inputs = tokenizer.apply_chat_template(messages, return_tensors="pt", add_generation_prompt=True).to("cuda" if torch.cuda.is_available() else "cpu")
outputs = model.generate(inputs, max_new_tokens=512)
cevap = tokenizer.decode(outputs[0][inputs.shape[-1]:], skip_special_tokens=False)

print("\n--- KUMRU'NUN CEVABI ---\n")
print(cevap)